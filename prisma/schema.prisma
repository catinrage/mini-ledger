generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Transaction {
  id String @id @default(cuid())

  party       String
  type        TransactionType
  amount      Float
  description String?

  // Due date fields - the only date for a transaction
  date                         DateTime?
  relativeDueDateTransactionId String?
  relativeDueDateOffsetDays    Int?
  relativeDueDateTransaction   Transaction?  @relation("RelativeDueDate", fields: [relativeDueDateTransactionId], references: [id], onDelete: SetNull)
  dependentTransactions        Transaction[] @relation("RelativeDueDate")

  deleted          Boolean @default(false)
  applied          Boolean @default(false)
  includeInBalance Boolean @default(true)

  recurringRuleId       String?
  recurringOccurrenceDate DateTime?
  recurringRule         RecurringTransactionRule? @relation(fields: [recurringRuleId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([recurringRuleId, recurringOccurrenceDate])
}

model Settings {
  id String @id @default(cuid())

  baselineBalance Float  @default(0)
  passkey         String  @default("1234")
  sessionToken    String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model RecurringTransactionRule {
  id String @id @default(cuid())

  party       String
  type        TransactionType
  amount      Float
  description String?

  frequency RecurrenceFrequency
  interval  Int
  startDate DateTime
  endDate   DateTime?

  active    Boolean   @default(true)
  stoppedAt DateTime?

  transactions Transaction[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum TransactionType {
  DEPOSIT
  WITHDRAW
}

enum RecurrenceFrequency {
  DAILY
  WEEKLY
  MONTHLY
  YEARLY
}
